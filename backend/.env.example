# ESBot Backend – Umgebungsvariablen
# Kopiere diese Datei nach ".env" und passe die Werte an.
# Die .env-Datei wird NICHT in Git eingecheckt (siehe .gitignore).

# ─────────────────────────────────────────────────────────
# Datenbankverbindung (PostgreSQL)
# Format: postgresql://BENUTZER:PASSWORT@HOST:PORT/DATENBANKNAME
#
# Lokal ohne Docker:  postgresql://esbot_user:esbot_password@localhost:5432/esbot
# Mit Docker Compose: postgresql://esbot_user:esbot_password@db:5432/esbot
# ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://esbot_user:esbot_password@localhost:5432/esbot

# ─────────────────────────────────────────────────────────
# Umgebung: development | test | production
# ─────────────────────────────────────────────────────────
APP_ENV=development
